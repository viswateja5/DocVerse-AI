# Dynamic Model Provider Configuration (supported: openai, gemini, groq, ollama)
MODEL_PROVIDER=groq

# Model Provider API Credentials
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# JWT Authentication Configuration
JWT_SECRET_KEY=generate_a_random_jwt_secret_here
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///vector_store/chat_history.db

# Redis Caching Configuration
REDIS_URL=redis://localhost:6379/0
